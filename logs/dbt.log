        tbl.relname as table_name,
        case tbl.relkind
            when 'v' then 'VIEW'
            when 'm' then 'MATERIALIZED VIEW'
            else 'BASE TABLE'
        end as table_type,
        tbl_desc.description as table_comment,
        col.attname as column_name,
        col.attnum as column_index,
        pg_catalog.format_type(col.atttypid, col.atttypmod) as column_type,
        col_desc.description as column_comment,
        pg_get_userbyid(tbl.relowner) as table_owner

    from pg_catalog.pg_namespace sch
    join pg_catalog.pg_class tbl on tbl.relnamespace = sch.oid
    join pg_catalog.pg_attribute col on col.attrelid = tbl.oid
    left outer join pg_catalog.pg_description tbl_desc on (tbl_desc.objoid = tbl.oid and tbl_desc.objsubid = 0)
    left outer join pg_catalog.pg_description col_desc on (col_desc.objoid = tbl.oid and col_desc.objsubid = col.attnum)
    where ((upper(sch.nspname) = upper('landing') and
           upper(tbl.relname) = upper('vendas')) or (upper(sch.nspname) = upper('intermediate') and
           upper(tbl.relname) = upper('int_vendas')) or (upper(sch.nspname) = upper('staging') and
           upper(tbl.relname) = upper('stg_clientes')) or (upper(sch.nspname) = upper('landing') and
           upper(tbl.relname) = upper('produtos')) or (upper(sch.nspname) = upper('landing') and
           upper(tbl.relname) = upper('clientes')) or (upper(sch.nspname) = upper('intermediate') and
           upper(tbl.relname) = upper('int_clientes')) or (upper(sch.nspname) = upper('marts') and
           upper(tbl.relname) = upper('fct_vendas')) or (upper(sch.nspname) = upper('marts') and
           upper(tbl.relname) = upper('dim_produtos')) or (upper(sch.nspname) = upper('marts') and
           upper(tbl.relname) = upper('dim_clientes')) or (upper(sch.nspname) = upper('staging') and
           upper(tbl.relname) = upper('stg_vendas')) or (upper(sch.nspname) = upper('staging') and
           upper(tbl.relname) = upper('stg_estorno')) or (upper(sch.nspname) = upper('intermediate') and
           upper(tbl.relname) = upper('int_produtos')) or (upper(sch.nspname) = upper('intermediate') and
           upper(tbl.relname) = upper('int_estorno')) or (upper(sch.nspname) = upper('staging') and
           upper(tbl.relname) = upper('stg_produtos')) or (upper(sch.nspname) = upper('landing') and
           upper(tbl.relname) = upper('estorno')))
      and not pg_is_other_temp_schema(sch.oid) -- not a temporary schema belonging to another session
      and tbl.relpersistence in ('p', 'u') -- [p]ermanent table or [u]nlogged table. Exclude [t]emporary tables
      and tbl.relkind in ('r', 'v', 'f', 'p', 'm') -- o[r]dinary table, [v]iew, [f]oreign table, [p]artitioned table, [m]aterialized view. Other values are [i]ndex, [S]equence, [c]omposite type, [t]OAST table
      and col.attnum > 0 -- negative numbers are used for system columns such as oid
      and not col.attisdropped -- column as not been dropped

    order by
        sch.nspname,
        tbl.relname,
        col.attnum
